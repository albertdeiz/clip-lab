generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VideoStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum TranscriptStatus {
  QUEUED
  TRANSCRIBING
  DONE
  FAILED
}

enum HighlightStatus {
  QUEUED
  DETECTING
  DONE
  FAILED
}

enum ClipStatus {
  QUEUED
  RENDERING
  READY
  FAILED
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  passwordHash  String? // null si la cuenta es solo OAuth
  emailVerified Boolean        @default(false)
  storageUsed   BigInt         @default(0) // bytes acumulados
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  oauthAccounts OAuthAccount[]
  videos        Video[]
  refreshTokens RefreshToken[]
}

model OAuthAccount {
  id             String @id @default(uuid()) @db.Uuid
  userId         String @db.Uuid
  provider       String // 'google'
  providerUserId String
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique // sha256 del token opaco
  familyId  String    @db.Uuid // rotación + detección de reuso
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
}

model Video {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @db.Uuid
  title       String
  status      VideoStatus @default(UPLOADING)
  storageKey  String      @unique
  sizeBytes   BigInt?
  durationSec Float?
  width       Int?
  height      Int?
  fps         Float?
  codec       String?
  container   String?
  bitrate     Int?
  failReason  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  upload       Upload?
  transcript   Transcript?
  highlightSet HighlightSet?
  clips        Clip[]
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
}

/** Clip corto (9:16) recortado de un highlight del video. */
model Clip {
  id          String     @id @default(uuid()) @db.Uuid
  videoId     String     @db.Uuid
  index       Int // orden (coincide con el ranking del highlight)
  title       String
  startSec    Float
  endSec      Float
  aspectRatio String     @default("9:16")
  status      ClipStatus @default(QUEUED)
  storageKey  String? // objeto S3 del clip renderizado
  sizeBytes   BigInt?
  width       Int?
  height      Int?
  durationSec Float?
  failReason  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  video       Video      @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId, index])
}

/**
 * Conjunto de highlights de un video. Es el artefacto IA persistido (§7 COST):
 * lleva modelo, hashes, versión, fecha y costo para caché/auditoría/incremental.
 */
model HighlightSet {
  id          String          @id @default(uuid()) @db.Uuid
  videoId     String          @unique @db.Uuid
  status      HighlightStatus @default(QUEUED)
  version     Int             @default(1)
  model       String? // modelo del rerank global
  localModel  String? // modelo del análisis por chunk
  promptHash  String?
  contentHash String? // hash del transcript → caché / reproceso incremental
  items       Json? // [{ start, end, score, title, reason }]
  costUsd     Decimal?        @db.Decimal(10, 6)
  failReason  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  video       Video           @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Transcript {
  id          String           @id @default(uuid()) @db.Uuid
  videoId     String           @unique @db.Uuid
  status      TranscriptStatus @default(QUEUED)
  language    String?
  model       String?
  text        String?
  words       Json? // [{ w, start, end }] word-level
  contentHash String? // hash del input → caché / reproceso incremental
  failReason  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  video       Video            @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Upload {
  id            String    @id @default(uuid()) @db.Uuid
  videoId       String    @unique @db.Uuid
  s3UploadId    String
  partSizeBytes Int
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  video         Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  aggregateType String // 'Video'
  aggregateId   String    @db.Uuid
  type          String // 'VideoUploaded'
  payload       Json
  createdAt     DateTime  @default(now())
  publishedAt   DateTime? // null = pendiente (relay se enciende en Fase 2)

  @@index([publishedAt, createdAt])
}
