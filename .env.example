# --- Core ---
NODE_ENV=development
API_PORT=4000
FRONTEND_ORIGIN=http://localhost:3000

# --- PostgreSQL ---
DATABASE_URL=postgresql://cliplab:cliplab@localhost:5432/cliplab?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- RabbitMQ ---
RABBITMQ_URL=amqp://cliplab:cliplab@localhost:5672

# --- Auth ---
JWT_SECRET=dev-only-change-me-please-32-chars-min
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=cliplab-videos
S3_ACCESS_KEY=cliplab
S3_SECRET_KEY=cliplab-secret

# --- Limits ---
MAX_STORAGE_PER_USER=53687091200   # 50 GB en bytes
MAX_UPLOAD_SIZE=2147483648         # 2 GB en bytes

# ============================================================================
# AI providers (registro genérico, por proceso)
# Presets conocidos: solo defines su API key y lo seleccionas por nombre.
#   anthropic · openai · deepseek · kimi/moonshot · qwen/dashscope ·
#   groq · openrouter · together · ollama
# Cualquier otro vendor / self-hosted / ngrok: usa un nombre libre y define
# la base URL + api key por-proceso (<PROCESO>_BASE_URL / <PROCESO>_API_KEY).
# ===========================================================================

# --- Credenciales de presets (define solo las que uses) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=      # Kimi
DASHSCOPE_API_KEY=     # Qwen (Alibaba)
GROQ_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
OLLAMA_API_KEY=

# --- Proceso: transcripción ---
TRANSCRIPTION_PROVIDER=faster-whisper   # faster-whisper | openai | groq | <n
WHISPER_MODEL=base                      # si faster-whisper (tiny.en/base dev; medium/large-v3 GPU prod)
TRANSCRIPTION_MODEL=whisper-1           # si proveedor API (p.ej. whisper-lar
# TRANSCRIPTION_BASE_URL=               # override o endpoint custom (openai-compatible)
# TRANSCRIPTION_API_KEY=                # override o key del endpoint custom

# --- Proceso: highlights (análisis local por chunk) ---
HIGHLIGHT_LOCAL_PROVIDER=anthropic      # p.ej. deepseek
HIGHLIGHT_LOCAL_MODEL=claude-haiku-4-5  # p.ej. deepseek-chat
# HIGHLIGHT_LOCAL_BASE_URL=
# HIGHLIGHT_LOCAL_API_KEY=

# --- Proceso: highlights (rerank global) ---
HIGHLIGHT_GLOBAL_PROVIDER=anthropic     # p.ej. kimi
HIGHLIGHT_GLOBAL_MODEL=claude-sonnet-5  # p.ej. moonshot-v1-8k
# HIGHLIGHT_GLOBAL_BASE_URL=            # p.ej. https://abc123.ngrok.app/v1 (self-hosted)
# HIGHLIGHT_GLOBAL_API_KEY=

CHUNK_SECONDS=150
CHUNK_OVERLAP_SECONDS=20
HIGHLIGHTS_TARGET=10

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000