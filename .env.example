# --- Core ---
NODE_ENV=development
API_PORT=4000
FRONTEND_ORIGIN=http://localhost:3000

# --- PostgreSQL ---
DATABASE_URL=postgresql://cliplab:cliplab@localhost:5432/cliplab?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=dev-only-change-me-please-32-chars-min
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=cliplab-videos
S3_ACCESS_KEY=cliplab
S3_SECRET_KEY=cliplab-secret

# --- Limits ---
MAX_STORAGE_PER_USER=53687091200   # 50 GB en bytes
MAX_UPLOAD_SIZE=2147483648         # 2 GB en bytes

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
