# ------------------------------------------------------------------
# ClipLab — variables de entorno (dev). Copia a .env: cp .env.example .env
# Validadas con Zod al boot (@clip-lab/config); si falta una crítica, el
# proceso falla rápido.
# ------------------------------------------------------------------

# --- General ---
NODE_ENV=development
API_PORT=4000
FRONTEND_ORIGIN=http://localhost:3000

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Infra (coinciden con infra/docker-compose.yml) ---
DATABASE_URL=postgresql://cliplab:cliplab@localhost:5432/cliplab?schema=public
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://cliplab:cliplab@localhost:5672

# ------------------------------------------------------------------
# IA — provider-agnóstica y seleccionable POR PROCESO por variables.
# Define solo las credenciales de los proveedores que uses. Presets conocidos:
# anthropic · openai · deepseek · kimi/moonshot · qwen/dashscope · groq ·
# openrouter · together · ollama. Para vendors arbitrarios/self-hosted usa las
# variables por-proceso *_BASE_URL / *_API_KEY.
# ------------------------------------------------------------------

# --- Credenciales de presets (set solo las que uses) ---
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# MOONSHOT_API_KEY=        # Kimi
# DASHSCOPE_API_KEY=       # Qwen (Alibaba)
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# TOGETHER_API_KEY=
# OLLAMA_API_KEY=

# --- Proceso: transcripción ---
# faster-whisper (local, requiere python3 + faster-whisper) | preset openai-compatible | custom
TRANSCRIPTION_PROVIDER=faster-whisper
WHISPER_MODEL=base                       # faster-whisper: tiny.en/base (dev) · medium/large-v3 (prod GPU)
TRANSCRIPTION_MODEL=whisper-1            # para proveedores API
# TRANSCRIPTION_BASE_URL=                # override / endpoint custom
# TRANSCRIPTION_API_KEY=

# --- Proceso: generación de momentos ---
# Modelo principal (análisis de una sola pasada) = GLOBAL.
# Modelo por sección (fallback de videos largos) = LOCAL.
HIGHLIGHT_GLOBAL_PROVIDER=anthropic
HIGHLIGHT_GLOBAL_MODEL=claude-sonnet-5
# HIGHLIGHT_GLOBAL_BASE_URL=
# HIGHLIGHT_GLOBAL_API_KEY=
HIGHLIGHT_LOCAL_PROVIDER=anthropic
HIGHLIGHT_LOCAL_MODEL=claude-haiku-4-5
# HIGHLIGHT_LOCAL_BASE_URL=
# HIGHLIGHT_LOCAL_API_KEY=

# Segmentación en frases (pausa que separa frases). El resto de parámetros de
# generación (cantidad, duración, granularidad, estilo, idioma, resumen) son
# on-demand vía el panel de generación (GenerationConfig), no van en env.
SENTENCE_PAUSE_SEC=0.8

# --- Proceso: generación de clips (FFmpeg) ---
CLIP_REFRAME=crop                        # crop | blur | fit
CLIP_WIDTH=1080
CLIP_HEIGHT=1920

# --- Auth ---
JWT_SECRET=dev-super-secret-change-me-min-32-characters-long
ACCESS_TOKEN_TTL=900                     # 15 min
REFRESH_TOKEN_TTL=2592000                # 30 días
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# --- Almacenamiento S3 (MinIO en dev) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=cliplab
S3_ACCESS_KEY=cliplab
S3_SECRET_KEY=cliplab-secret

# --- Cuotas ---
MAX_STORAGE_PER_USER=53687091200         # 50 GiB
MAX_UPLOAD_SIZE=2147483648               # 2 GiB